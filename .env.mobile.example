# ===========================================
# CONFIGURACIÓN PARA APLICACIÓN MÓVIL
# ===========================================

# URL base de la API (IMPORTANTE para móvil)
# Desarrollo local:
VITE_API_URL=http://localhost:8000/api

# Para dispositivo Android real en red local:
# VITE_API_URL=http://192.168.1.100:8000/api
# (Reemplazar 192.168.1.100 con la IP de tu PC)

# Para emulador Android:
# VITE_API_URL=http://10.0.2.2:8000/api

# Para producción:
# VITE_API_URL=https://tu-dominio.com/api

# ===========================================
# CONFIGURACIÓN ESTÁNDAR DE LARAVEL
# ===========================================

APP_NAME="Ferreteria TOTORO"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

# ===========================================
# BCRYPT
# ===========================================

BCRYPT_ROUNDS=12

# ===========================================
# LOG
# ===========================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================================
# BASE DE DATOS
# ===========================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tlapaleria
DB_USERNAME=root
DB_PASSWORD=

# ===========================================
# SESSION
# ===========================================

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ===========================================
# BROADCASTING
# ===========================================

BROADCAST_CONNECTION=log

# ===========================================
# FILESYSTEM
# ===========================================

FILESYSTEM_DISK=local

# ===========================================
# QUEUE
# ===========================================

QUEUE_CONNECTION=database

# ===========================================
# CACHE
# ===========================================

CACHE_STORE=database
CACHE_PREFIX=

# ===========================================
# REDIS
# ===========================================

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# MAIL
# ===========================================

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# AWS (si se usa para almacenamiento)
# ===========================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# VITE
# ===========================================

VITE_APP_NAME="${APP_NAME}"

# ===========================================
# CONFIGURACIÓN ESPECÍFICA PARA MÓVIL
# ===========================================

# Tiempo de expiración del token (en minutos)
# Por defecto Passport: 1 año
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=

# Configuración de CORS para API
# Ya configurado en config/cors.php

# Habilitar debug en móvil
VITE_DEBUG_MODE=true

# Versión de la app móvil
VITE_APP_VERSION=1.0.0
